---
import Welcome from '../components/Welcome.astro';
import Layout from '../layouts/Layout.astro';

const structuredData = [
	{
		"@context": "https://schema.org",
		"@type": "WebPage",
		name: "Serwer Minecraft Polska - HEX Network",
		description: "HEX Network to serwer Minecraft Polska z turniejami, eventami, rankingiem graczy i autorskimi trybami rozgrywki.",
		url: "https://www.minecrafthex.pl/"
	},
	{
		"@context": "https://schema.org",
		"@type": "FAQPage",
		mainEntity: [
			{
				"@type": "Question",
				name: "Jak zapisac sie na turniej Minecraft?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Wiekszosc wydarzen nie wymaga wczesniejszych zapisow. Dolacz na Discord HEX oraz obserwuj nasze social media i ogloszenia, aby byc na biezaco."
				}
			},
			{
				"@type": "Question",
				name: "Jak grac w rozne tryby na serwerze Minecraft HEX?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Po wejsciu na serwer Minecraft trafiasz do lobby, z ktorego mozesz wybrac interesujacy Cie tryb gry przechodzac przez odpowiedni portal."
				}
			},
			{
				"@type": "Question",
				name: "Co musze zrobic, aby dolaczyc na serwer Minecraft HEX?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Musisz posiadac Minecraft Java Edition. Zadziala Premium jak i Non-premium. Wymagana wersja gry to 1.21.1, a adres serwera to MinecraftHEX.pl."
				}
			}
		]
	},
	{
		"@context": "https://schema.org",
		"@type": "Event",
		name: "Turniej Minecraft HEX",
		eventAttendanceMode: "https://schema.org/OnlineEventAttendanceMode",
		eventStatus: "https://schema.org/EventScheduled",
		startDate: "2026-04-03T19:00:00+01:00",
		endDate: "2026-04-04T23:00:00+01:00",
		image: ["https://www.minecrafthex.pl/logo.png"],
		description: "Turniej Minecraft HEX z nagrodami, rankingiem graczy i aktywna spolecznoscia Discord.",
		location: {
			"@type": "VirtualLocation",
			url: "https://www.minecrafthex.pl"
		},
		organizer: {
			"@type": "Organization",
			name: "HEX Network",
			url: "https://www.minecrafthex.pl"
		}
	},
	{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		itemListElement: [
			{
				"@type": "ListItem",
				position: 1,
				name: "Strona glowna",
				item: "https://www.minecrafthex.pl/"
			}
		]
	}
];

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout 
	customTitle="Serwer Minecraft Polska - turnieje, eventy, PVP i Parkour | HEX Network" 
	customDescription="HEX Network to serwer Minecraft Polska z turniejami, eventami, rankingiem graczy i autorskimi trybami: Event Zone, Mini Games, PVP, Parkour i Hardcore SMP."
	ogImage="https://www.minecrafthex.pl/logo.png"
	canonicalUrl="https://www.minecrafthex.pl/"
	structuredData={structuredData}
>
	<Welcome />
</Layout>
