---
import Layout from '../layouts/Layout.astro';
const RegulationsPageComponent = (await import('../components/Regulations.astro')).default;

const structuredData = [
	{
		"@context": "https://schema.org",
		"@type": "WebPage",
		name: "Regulamin sklepu HEX Network",
		description: "Regulamin sklepu HEX Network obejmujący zasady zakupu usług cyfrowych, płatności, reklamacji i realizacji zamówień.",
		url: "https://www.minecrafthex.pl/regulations/"
	},
	{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		itemListElement: [
			{
				"@type": "ListItem",
				position: 1,
				name: "Strona główna",
				item: "https://www.minecrafthex.pl/"
			},
			{
				"@type": "ListItem",
				position: 2,
				name: "Regulamin sklepu",
				item: "https://www.minecrafthex.pl/regulations/"
			}
		]
	}
];
---

<Layout 
	customTitle="Regulamin sklepu HEX Network | usługi cyfrowe i płatności" 
	customDescription="Poznaj regulamin sklepu HEX Network: zasady zakupu usług cyfrowych, płatności, reklamacji, realizacji zamówień i odpowiedzialności administratora."
	canonicalUrl="https://www.minecrafthex.pl/regulations"
	structuredData={structuredData}
>
	<RegulationsPageComponent />
</Layout>