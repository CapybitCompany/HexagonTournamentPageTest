---
import HexHardcoreSmpPage from '../components/PageContent/ServerArticles/HexHardcoreSmp.astro';
import Layout from '../layouts/Layout.astro';

const structuredData = [
	{
		"@context": "https://schema.org",
		"@type": "WebPage",
		name: "HEX Hardcore SMP",
		description: "Strona trybu HEX Hardcore SMP z zasadami śmierci, banów czasowych, rang i Heart Fragmentów.",
		url: "https://www.minecrafthex.pl/hexHardcoreSmp/"
	},
	{
		"@context": "https://schema.org",
		"@type": "FAQPage",
		mainEntity: [
			{
				"@type": "Question",
				name: "Jak naliczany jest ban po smierci?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Ban rosnie wraz z czasem przezycia i liczba zabojstw, zgodnie z zasadami trybu Hardcore SMP."
				}
			},
			{
				"@type": "Question",
				name: "Do czego sluza Heart Fragmenty?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Heart Fragmenty skracaja czas bana po smierci i pomagaja szybciej wrocic do gry."
				}
			},
			{
				"@type": "Question",
				name: "Gdzie sledzic ogloszenia dla Hardcore SMP?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Najwazniejsze komunikaty i zapisy publikujemy na Discordzie HEX oraz stronie glownej."
				}
			}
		]
	},
	{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		itemListElement: [
			{
				"@type": "ListItem",
				position: 1,
				name: "Strona glowna",
				item: "https://www.minecrafthex.pl/"
			},
			{
				"@type": "ListItem",
				position: 2,
				name: "Hardcore SMP",
				item: "https://www.minecrafthex.pl/hexHardcoreSmp/"
			}
		]
	}
];
---

<Layout
	customTitle="HEX Hardcore SMP - serwer Minecraft w przygotowaniu"
	customDescription="HEX Hardcore SMP - nowy serwer Minecraft z zasadami HEX i systemem tymczasowych banów zależnych od statystyk."
	canonicalUrl="https://www.minecrafthex.pl/hexHardcoreSmp"
	structuredData={structuredData}
>
	<HexHardcoreSmpPage />
</Layout>
