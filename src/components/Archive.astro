---
import NavBar from './NavBar/NavBar.astro'
import Footer from './Footer/Footer.astro'
import ContentContainer from './ContentContainer/ContentContainer.astro'
import ImageBoxContent from './ImageBoxContent/ImageBoxContent.astro'
import './NavBar/NavBar.css'
import './PageContent/WelcomePage/Welcome.styles.css'
import FullImageContainer from './FullImageContainer/FullImageContainer.astro'
import Grid21 from './Grid/Grid2_1/Grid2_1.astro'
import TimeContainer from './DiscordContainer/TimeContainer.astro'
import Section from './ContentContainer/Section.astro'
---

<NavBar/>
<ContentContainer>
    <FullImageContainer imagePath="images/Archive/Banner.png" imageLink="#" wrapperClass="blackBackground" wrapperStyle="height: 500px;" altText="Archiwum turniejow Minecraft HEX - poprzednie edycje, zwyciezcy i nagrody">
        <div style="width: 100%; height: 100%; display: flex; justify-content: center; align-items: center;">
            <h1 class="archiveBannerText">Archiwum turniejów</h1>
        </div>
    </FullImageContainer>

    <Section>
        <section class="archiveSeoIntro">
            <h2>Historia turniejow HEX Network</h2>
            <p>W archiwum znajdziesz poprzednie edycje turniejow Minecraft HEX: daty, liczbe graczy, pule nagrod i zwyciezcow.</p>
            <p>To miejsce, w ktorym dokumentujemy rozwoj wydarzen i najwazniejsze momenty kazdego sezonu.</p>
        </section>

        <h1 class="eventHeader">Truniej Hex VI - Świąteczny</h1>

        <Grid21>
            <ImageBoxContent slot="left" imagePath="images/Archive/Hex6/1.jpg" lazyMeanColor="#dcc5ea" isLightBox wrapperClass="small">
                <div class="fullWidthTileContent" style="text-align: center;">
                    <p style="font-size: 1.8rem; font-weight: 600;"> <b>Nagroda:</b></p>
                    <h1>400zł + 200zł w bonusach</h1>
                    
                </div>
            </ImageBoxContent>
            <ImageBoxContent slot="left" imagePath="images/Archive/Hex6/2.jpg" lazyMeanColor="#dcc5ea" wrapperClass="imageRight small" isLightBox>
                <div class="fullWidthTileContent" style="text-align: center;">
                    <p style="font-size: 1.8rem; font-weight: 600;"> <strong>Zwycięzca: </strong></p>
                    <h1>Grzesztof</h1>
                </div>
            </ImageBoxContent>
        </Grid21>

        <Grid21>
            <ImageBoxContent slot="left" imagePath="images/Archive/Hex6/3.jpg" lazyMeanColor="#dcc5ea" isLightBox>
                <div class="fullWidthTileContent" style="text-align: center;">
                    <p style="font-size: 1.8rem; font-weight: 600;">Data: <strong>13.12.2025</strong></p>
                    <p style="font-size: 1.8rem; font-weight: 600;">Liczba graczy: <strong>35</strong></p>
                </div>
            </ImageBoxContent>
            <ImageBoxContent slot="left" imagePath="images/Archive/Hex6/4.jpg" lazyMeanColor="#dcc5ea" wrapperClass="imageRight" isLightBox>
                <div class="fullWidthTileContent" style="text-align: center;">
                        <h1>Gry:</h1>
                        <ol>
                            <li>Budowa Renifera</li>
                            <li>Kevin sam w domu</li>
                            <li>Czerwone Zielone</li>
                            <li>Mob Race</li>
                            <li>Spleef</li>
                            <li>Final boss: Yeti</li>
                        </ol>
                    <!-- <a href="/frontendAndBackendSubject"><b>Więcej informacji</b></a> -->
                </div>
            </ImageBoxContent>
        </Grid21>


        <h1 class="eventHeader">Truniej Hex V - inspirowana światem Harrego Pottera</h1>

