<Footer/>

<style>
    .eventHeader {
        margin: 100px 0 40px 0;
    }

    .archiveSeoIntro,
    .archiveFaq {
        display: flex;
        text-align: center;
        flex-direction: column;
        gap: 10px;
        width: 100%;
    }

    .archiveSeoIntro p {
        margin: 0;
        line-height: 1.6;
    }

    .archiveFaq {
        width: min(1100px, 96%);
        margin: 10px auto 0 auto;
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 18px;
        padding: 16px;
        color: #f6f0dd;
        background: linear-gradient(155deg, #222833 0%, #151920 55%, #10141a 100%);
        position: relative;
        overflow: hidden;
        box-shadow: 0 14px 32px rgba(0, 0, 0, 0.2);
    }

    .archiveFaq::before {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        background: radial-gradient(circle at 10% 0%, rgba(255, 195, 87, 0.2), transparent 42%);
    }

    .archiveFaq h2 {
        margin: 0 0 4px 0;
        position: relative;
        z-index: 1;
    }

    .archiveFaq article {
        border: 1px solid rgba(255, 255, 255, 0.14);
        border-radius: 12px;
        padding: 10px 12px;
        background: rgba(0, 0, 0, 0.24);
        position: relative;
        z-index: 1;
    }

    .archiveFaq h3 {
        margin: 0 0 6px 0;
        color: #ffd88c;
    }

    .archiveFaq p {
        margin: 0;
        line-height: 1.6;
    }

    li {
        text-align: left;
    }

    .archiveBannerText{
        color: white;
        font-size: 6rem;
        font-family: "minecraft";
    }

    @media(max-width: 870px){
        .archiveBannerText{
            font-size: 4rem;
        }
        
    }
</style>
