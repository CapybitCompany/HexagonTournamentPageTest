---
var {src, headerText, href, comingSoon = false, soonText = "Niebawem" } = Astro.props;
---
<div class="discordContainerWrapper">
    <a href={comingSoon ? undefined : href} aria-disabled={comingSoon ? "true" : "false"} class={comingSoon ? "disabledLink" : ""}>
        <div class="discordContainer">
            <div class="headerWrapper">
                <h2 class="discordHeader">{headerText}</h2>
            </div>

            <div class="imageContainer">
                {
                    src ? (
                        <img class="hexImage" src={src} alt={headerText}/>
                    ) : (
                        <div class="hexPlaceholder" aria-label={`${headerText} - ${soonText}`}>
                            <span>{soonText}</span>
                        </div>
                    )
                }
            </div>
        </div>
    </a>
</div>

<style>
    .discordContainerWrapper > a {
        display: block;
        width: 100%;
        color: inherit;
        text-decoration: none;
    }

    .discordContainerWrapper{
        width: 100%;
        justify-content: center;
        margin: 10px 15px;
    }

    .discordContainer {
        width: 100%;
        max-width: 100%;
        height: 300px;
        max-height: 300px;
        flex-direction: column;
        background-color: #ffffff27;
        color: white;
        border-radius: 20px;
        align-items: center;
        justify-content: center;

        overflow: hidden;
        transition: background-color 0.2s ease;
    }

    .disabledLink {
        cursor: default;
        text-decoration: none;
    }

    .discordContainer a{
        width: 100%;
        max-height: 70%;
    }

    .hexImage { transform-origin: center; }

    .imageContainer img,
    .hexImage {
        width: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.2s ease;
        transform: scale(1);
    }

    /* hover: rozjaśnij tło + powiększ img */
    .discordContainerWrapper:hover .discordContainer {
        background-color: #ffffff40;
    }

    .discordContainerWrapper:hover .imageContainer img,
    .discordContainerWrapper:hover .hexImage {
        transform: scale(1.2);
    }

    .discordContainerWrapper:hover .hexPlaceholder {
        filter: brightness(1.12);
    }


    .headerWrapper{
        flex-direction: row;
        justify-content: center;
        align-items: center;
        color: white;
        font-family: "minecraft";
    }
    .headerWrapper h2{
        margin: 5px 0;
    }
    
    .subHeaderWrapper{
        flex-direction: row;
        justify-content: center;
        align-items: center;
        margin: 0px 10px 15px 0px;
        color: white;
    }
    .discordHeader {
        text-align: center;
    }
    .discordSubHeader {
        margin: 0 0 0 15px;
        text-align: center;
    }
    .discordText {
        color: white;
        text-align: center;
    }
    .discordUrl{
        display: flex;
        align-items: center;
        justify-content: center;
        margin-top: 20px;
        margin-bottom: 10px;
        text-decoration: none;
        color: 	#7289da;
        font-weight: 600;
        font-size: 32px;
    }
    .discordUrl:hover{
        color: 	#b8c4f0;
    }

    .discordIcon {
        width: 50px;
        height: 50px;
        margin-right: 10px;
        overflow: hidden;
    }

    .discordIcon svg{
        width: 50px !important;
        height: 50px !important; 
    }

    .imageContainer{
        width: 100%;
        height: 240px;
    }

    img{
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .hexPlaceholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        background-image: url("/images/stonebrick.jpg");
        background-repeat: repeat;
        background-size: 128px 128px;
        overflow: hidden;
        transition: filter 0.2s ease;
    }

    .hexPlaceholder::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(rgba(0, 0, 0, 0.3), rgba(0, 0, 0, 0.88));
        pointer-events: none;
    }

    .hexPlaceholder span {
        position: relative;
        z-index: 1;
        font-family: "minecraft";
        font-size: clamp(1.55rem, 3.8vw, 2.25rem);
        color: #ffcf5a;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }

    @media (max-width: 980px){
        .discordContainerWrapper{
            margin: 10px 0;
        }
        .discordContainer{
            max-width: 100%;
        }
        .imageContainer{
            width: 100%;
            height: 240px;
        }
        img{
            object-fit: cover;
        }
    }

</style>