---
import NavBar from '../../NavBar/NavBar.astro'
import Footer from '../../Footer/Footer.astro'
import ContentContainer from '../../ContentContainer/ContentContainer.astro'
import FullImageContainer from '../../FullImageContainer/FullImageContainer.astro'
import '../../NavBar/NavBar.css'
import '../WelcomePage/Welcome.styles.css'
import './ServerArticle.styles.css'
import TimeContainer from '../../DiscordContainer/TimeContainer.astro'
import Section from '../../ContentContainer/Section.astro'
---

<NavBar/>
<ContentContainer>
    <FullImageContainer imagePath="images/construction.jpeg" imageLink="#" wrapperClass="blackBackground construction" altText="Serwer PVP Minecraft HEX - strona w przygotowaniu">
        <div style="width: 100%; height: 100%; display: flex; justify-content: center; align-items: center;">
            <h1 class="archiveBannerText"></h1>
        </div>
    </FullImageContainer>

    <div style="display: flex; width: 100%; justify-content: center;">
        <TimeContainer />
    </div>

    <Section>
        <article class="serverArticle">
            <header class="articleHeader">
                <p class="statusKicker">Status projektu</p>
                <h1>Serwer PVP</h1>
                <p class="articleLead">Serwer PVP jest w przygotowaniu. Dopracowujemy zestaw aren, balans i systemy rankingowe.</p>
            </header>

            <div class="articleColumns">
                <section>
                    <h2>Filozofia rozgrywki</h2>
                    <p>Stawiamy na czytelny balans i dynamiczne pojedynki, bez przesadnej przewagi jednego stylu walki.</p>
                </section>

                <section>
                    <h2>Zakres wersji startowej</h2>
                    <ul>
                        <li>Areny 1v1 i formaty drużynowe.</li>
                        <li>Ranking oparty o wyniki i aktywność.</li>
                        <li>Regularne aktualizacje balansu.</li>
                    </ul>
                </section>
            </div>

            <section class="faqSection">
                <h2>FAQ - PVP</h2>
                <div class="faqList">
                    <!-- <article class="faqItem">
                        <h3>Czy na serwerze PVP beda tryby 1v1 i team?</h3>
                        <p>Tak, planujemy areny 1v1 oraz formaty druzynowe z osobnymi tabelami wynikow.</p>
                    </article>
                    <article class="faqItem">
                        <h3>Jak dziala ranking PVP?</h3>
                        <p>Ranking bedzie oparty o zwyciestwa, serie wygranych i aktywnosc w sezonie.</p>
                    </article> -->
                    <article class="faqItem">
                        <h3>Gdzie zglaszac uwagi do balansu?</h3>
                        <p>Feedback i propozycje zmian balansu zbieramy na Discordzie HEX.</p>
                    </article>
                </div>
            </section>

            <p class="comingSoon">NIEBAWEM</p>
        </article>
    </Section>
</ContentContainer>
<Footer/>
